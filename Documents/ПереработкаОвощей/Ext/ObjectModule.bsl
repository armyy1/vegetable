#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	
	Движения.ОстаткиТоваров.Записывать = Истина;
	
	Для Каждого СтрокаТовары Из Товары Цикл
		
		Если Не ЗначениеЗаполнено(СтрокаТовары.ВидОпераций) Тогда
			ВидОперации = Перечисления.ВидыОперации.Очистка;
		Иначе
			ВидОперации = СтрокаТовары.ВидОпераций;
		КонецЕсли;
		
		КоличествоПотерь = СтрокаТовары.КоличествоПотерь;
		Если Не ЗначениеЗаполнено(КоличествоПотерь) Тогда
			КоличествоПотерь = 0;
		КонецЕсли;
		
		КоличествоПродукции = СтрокаТовары.КоличествоПродукция;
		Если Не ЗначениеЗаполнено(КоличествоПродукции) Тогда
			КоличествоПродукции = СтрокаТовары.КоличествоСырье - КоличествоПотерь;
		КонецЕсли;
		
		Если КоличествоПродукции < 0 Тогда
			КоличествоПродукции = 0;
		КонецЕсли;
		
		// Расход сырья со склада-источника.
		Движение = Движения.ОстаткиТоваров.Добавить();
		Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
		Движение.Период = Дата;
		Движение.Склад = СкладИсточник;
		Движение.Номенклатура = СтрокаТовары.НоменклатураСырье;
		Движение.ВидОпераций = ВидОперации;
		Движение.Количество = СтрокаТовары.КоличествоСырье;
		
		// Приход готовой продукции на склад-приемник.
		Если КоличествоПродукции > 0 Тогда
			Движение = Движения.ОстаткиТоваров.Добавить();
			Движение.ВидДвижения = ВидДвиженияНакопления.Приход;
			Движение.Период = Дата;
			Движение.Склад = СкладПриемник;
			Движение.Номенклатура = СтрокаТовары.НоменклатураПродукция;
			Движение.ВидОпераций = ВидОперации;
			Движение.Количество = КоличествоПродукции;
		КонецЕсли;
		
		// Потери списываются как отдельная расходная операция.
		Если КоличествоПотерь > 0 Тогда
			Движение = Движения.ОстаткиТоваров.Добавить();
			Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
			Движение.Период = Дата;
			Движение.Склад = СкладИсточник;
			Движение.Номенклатура = СтрокаТовары.НоменклатураСырье;
			Движение.ВидОпераций = Перечисления.ВидыОперации.СписаниеПотерь;
			Движение.Количество = КоличествоПотерь;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

#Иначе
ВызватьИсключение НСтр("ru = 'Недопустимый вызов объекта на клиенте.'");
#КонецЕсли
